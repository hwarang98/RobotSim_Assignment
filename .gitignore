# =========================
# Unreal Engine 프로젝트 Git Ignore
# =========================

# ---------------------------------
# Visual Studio / IDE 캐시 파일
# ---------------------------------

.vs/
*.VC.db
*.VC.opendb
*.suo
*.sdf
*.opensdf
*.vsconfig

# JetBrains Rider
.idea/

# VSCode
.vscode/

# MacOS 시스템 파일
.DS_Store

# ---------------------------------
# 언리얼에서 생성되는 바이너리 파일
# (빌드 시 자동 생성되므로 Git에 포함하지 않음)
# ---------------------------------

Binaries/
Plugins/*/Binaries/

# ---------------------------------
# 빌드 산출물
# ---------------------------------

Builds/

# ---------------------------------
# 컴파일 중간 파일
# (Visual Studio / Unreal Build Tool이 생성)
# ---------------------------------

Intermediate/
Plugins/*/Intermediate/

# ---------------------------------
# Unreal Engine 캐시
# (머신마다 생성되는 캐시라서 절대 커밋하면 안됨)
# ---------------------------------

DerivedDataCache/

# ---------------------------------
# 에디터 실행 중 생성되는 임시 파일
# ---------------------------------

Saved/

# ---------------------------------
# 맵 빌드 데이터
# (라이팅 빌드 시 자동 생성)
# ---------------------------------

*_BuiltData.uasset

# ---------------------------------
# 컴파일된 오브젝트 파일
# ---------------------------------

*.obj
*.o
*.lo
*.slo
*.pch
*.gch

# ---------------------------------
# 정적 라이브러리
# ---------------------------------

*.lib
*.a
*.la
*.lai

# ---------------------------------
# 동적 라이브러리
# ---------------------------------

*.dll
*.so
*.dylib

# ---------------------------------
# 실행 파일
# ---------------------------------

*.exe
*.out
*.app
*.ipa

# ---------------------------------
# IDE에서 생성되는 프로젝트 파일
# (Generate Project Files로 재생성 가능)
# ---------------------------------

*.xcodeproj
*.xcworkspace
*.sln

# ---------------------------------
# 중요 폴더는 반드시 Git에 포함
# ---------------------------------

!Source/**
!Content/**
!Config/**
!Plugins/**
/Ashen_Cathedral.sln.DotSettings.user
/.claude/settings.local.json
